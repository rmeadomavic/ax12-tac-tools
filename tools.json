{
  "categories": [
    {
      "name": "TAK",
      "tools": [
        {
          "label": "ATAK BRIDGE",
          "description": "Stream drone position to ATAK",
          "cmd": "su 0 /data/data/com.termux/files/usr/bin/python3 ~/ax12-tac-tools/tools/cot_bridge.py",
          "shortcut": "atak",
          "requires": ["root", "serial:/dev/ttyS1"],
          "long_running": true
        },
        {
          "label": "COT TEST",
          "description": "Send one test blip to verify ATAK",
          "cmd": "/data/data/com.termux/files/usr/bin/python3 ~/ax12-tac-tools/tools/test_cot.py",
          "shortcut": "cot-test",
          "requires": [],
          "long_running": false,
          "timeout": 15
        }
      ]
    },
    {
